# ─────────────────────────────────────────────
#  Burndown Stack  –  Environment Variables
#  Save as .env (next to docker-compose.yml)
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=burndown
POSTGRES_USER=burndown
POSTGRES_PASSWORD=SECURE_PASSWORD_HERE

# InvoiceNinja
INVOICENINJA_URL=https://your-invoiceninja-instance.example.com
INVOICENINJA_API_KEY=YOUR_API_KEY_HERE

# Sync Worker
SYNC_INTERVAL_MINUTES=10

# API (optional)
# CORS_ORIGIN=http://localhost:8088   # Allowed CORS origin; leave unset to deny all cross-origin requests
