# ─────────────────────────────────────────────
#  Burndown Stack  –  Umgebungsvariablen
#  Als .env speichern (neben docker-compose.yml)
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=burndown
POSTGRES_USER=burndown
POSTGRES_PASSWORD=SICHERES_PASSWORT_HIER

# InvoiceNinja
INVOICENINJA_URL=https://deine-invoiceninja-instanz.de
INVOICENINJA_API_KEY=DEIN_API_KEY_HIER

# Sync Worker
SYNC_INTERVAL_MINUTES=10

# API (optional)
# CORS_ORIGIN=http://localhost:8088   # Allowed CORS origin; leave unset to deny all cross-origin requests
